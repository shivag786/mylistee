# ---------------------------------------------------------------------------
# Listee frontend environment. Copy to `.env` and fill in real values.
# Only VITE_-prefixed vars are exposed to the client bundle (Vite rule).
# Never commit the real .env — secrets belong in the server, not the client.
# ---------------------------------------------------------------------------

# Backend API (Laravel) — versioned base URL
VITE_API_BASE_URL=http://localhost:8000/api/v1

# App
VITE_APP_NAME=Listee
VITE_APP_ENV=local

# Firebase (Google Auth + Cloud Messaging) — from Firebase console
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
# Web Push certificate key pair (Cloud Messaging → Web configuration)
VITE_FIREBASE_VAPID_KEY=
