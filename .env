# ── Listee frontend — PRODUCTION env template (Milestone 18) ──
# Copy to `.env.production` (Vite reads it for `npm run build`). Vars are baked
# into the bundle at build time, so treat them as public (no secrets here).

VITE_APP_NAME=Listee
VITE_APP_ENV=production

# Backend API base — must include /api/v1
VITE_API_BASE_URL=https://violet-wolverine-654222.hostingersite.com/api/v1

# Firebase Web (Google sign-in + FCM). From the Firebase console web app config.
VITE_FIREBASE_API_KEY=AIzaSyCLPAdrTtDZZRDAwvuZWqDKCw8k9HLqTq8
VITE_FIREBASE_AUTH_DOMAIN="shammtech-415b8.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="shammtech-415b8"
VITE_FIREBASE_STORAGE_BUCKET="shammtech-415b8.firebasestorage.app"
VITE_FIREBASE_MESSAGING_SENDER_ID="824904723551"
VITE_FIREBASE_APP_ID="1:824904723551:web:9f7afd702bad3c4ddaffea"
VITE_FIREBASE_VAPID_KEY="BAxRZw-vGKVYq6YWC5Okx-Xo9vwKnlXPJrXdhYfm7384-VhnVXIbOSDcVQdODOOpV_-zrMvJJvN6-qMxPQCOfVQ"

