# Local development overrides — loaded ONLY by `npm run dev`, never by `npm run build`.
# Keeps dev pointed at the local Laravel server; production values live in `.env`
# (and/or `.env.production`) and are used for builds. Vite precedence: .env.development
# overrides .env in development mode.

VITE_APP_ENV=local

# Local Laravel API (php artisan serve)
VITE_API_BASE_URL=http://localhost:8000/api/v1

# Show the seeded demo admin credentials on the staff login page locally.
VITE_DEMO_MODE=true
