<?xml version="1.0" encoding="UTF-8"?>
<!--
  Static sitemap of the public customer pages. Individual business profiles
  (/b/{slug}) are dynamic and should be added by a backend-generated sitemap in
  production; this covers the crawlable entry points.
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">
  <url>
    <loc>/</loc>
    <changefreq>daily</changefreq>
    <priority>1.0</priority>
  </url>
  <url>
    <loc>/nearby</loc>
    <changefreq>daily</changefreq>
    <priority>0.8</priority>
  </url>
  <url>
    <loc>/search</loc>
    <changefreq>weekly</changefreq>
    <priority>0.6</priority>
  </url>
</urlset>
